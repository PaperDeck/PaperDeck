// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Feed {
  url       String    @id
  title     String
  createdAt DateTime  @default(now())
  articles  Article[]
}

model Article {
  id      String    @id
  title   String
  link    String    @unique
  summary String?
  content String?
  pubDate DateTime?
  isRead  Boolean   @default(false)

  feed   Feed   @relation(fields: [feedUrl], references: [url], onDelete: Cascade)
  feedUrl String

  createdAt DateTime @default(now())

  @@index([pubDate])
  @@index([isRead])
}
