{
  "name": "reader",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently --kill-others \"electron-rebuild -f -w better-sqlite3 && vite\" \"npx react-devtools\"",
    "build-vite": "electron-rebuild -f -w better-sqlite3 && tsc -b && vite build",
    "prebuild": "node scripts/generate-db.js && npx prisma generate",
    "lint": "eslint .",
    "preview": "vite preview",
    "build": "npm run prebuild && npm run build-vite && electron-builder --dir",
    "prepare": "husky",
    "test:db-push": "dotenv -e .env.test -- npx prisma db push",
    "test:unit": "npm run test:db-push && npm rebuild better-sqlite3 && vitest run tests/unit --coverage",
    "test:integration": "npm run test:db-push && npm rebuild better-sqlite3 && vitest run tests/integration --coverage",
    "test": "npm run test:db-push && npm rebuild better-sqlite3 && vitest run --coverage"
  },
  "build": {
    "appId": "com.reader.app",
    "productName": "Reader",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "package.json",
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "resources/**/*"
    ]
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-virtual": "^3.13.21",
    "@types/lodash": "^4.17.24",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "dompurify": "^3.3.2",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "electron-store": "^11.0.2",
    "html-react-parser": "^5.2.17",
    "i18next": "^25.8.14",
    "lodash": "^4.18.1",
    "lucide-react": "^0.577.0",
    "p-limit": "^7.3.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-devtools": "^7.0.1",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.5.6",
    "react-intersection-observer": "^10.0.3",
    "react-router": "^7.13.1",
    "react-shiki": "^0.9.2",
    "rss-parser": "^3.13.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "zustand": "^5.0.11"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown",
    "*.{js,ts,vue}": "eslint --fix"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.2.4",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-html": "^3.2.2",
    "vitest": "^4.0.18"
  }
}
